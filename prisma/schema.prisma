// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  role         String  @default("employee") // "employee", "manager", "admin"
  department   String?
  title        String?
  avatarUrl    String?
  passwordHash String?

  tags Tag[] @relation("UserTags")

  // Submissions created by this user
  timesheets      Timesheet[]      @relation("TimesheetSubmitter")
  transferRecords TransferRecord[] @relation("TransferSubmitter")
  incidentReports IncidentReport[] @relation("IncidentSubmitter")
  timeOffRequests TimeOffRequest[] @relation("TimeOffSubmitter")
  fundingRequests FundingRequest[] @relation("FundingSubmitter")
  snowRemovalLogs SnowRemovalLog[] @relation("SnowLogSubmitter")

  // Authored interactions
  comments     Comment[]  @relation("CommentAuthor")
  uploadedDocs Document[] @relation("DocumentUploader")

  capExRequests        CapExRequest[] @relation("CapExSubmitter")

  transferDraft String?

  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id   String @id @default(cuid())
  name String @unique // e.g. "MB Manager", "ADMIN", "MB Employee"
  type String // "MANAGER", "EMPLOYEE", "ADDITIONAL"

  users User[] @relation("UserTags")

  // Many-To-Many Form Assignments
  assignedTimesheets      Timesheet[]      @relation("TimesheetTagApprovers")
  assignedTransferRecords TransferRecord[] @relation("TransferTagApprovers")
  assignedIncidentReports IncidentReport[] @relation("IncidentTagApprovers")
  assignedTimeOff         TimeOffRequest[] @relation("TimeOffTagApprovers")
  assignedFunding         FundingRequest[] @relation("FundingTagApprovers")
  assignedSnowLogs        SnowRemovalLog[] @relation("SnowLogTagApprovers")

  visibleDocuments Document[] @relation("DocumentVisibilityTags")
}

model DocumentCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  
  documents   Document[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Document {
  id         String @id @default(cuid())
  name       String
  type       String // "pdf", "docx", "xlsx"
  sizeBytes  Int
  
  categoryId String
  category   DocumentCategory @relation(fields: [categoryId], references: [id])

  visibilityTags Tag[] @relation("DocumentVisibilityTags")

  filePath   String? // Store physical file path on server

  authorId String?
  author   User?   @relation("DocumentUploader", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id      String @id @default(cuid())
  content String

  authorId String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id])

  // Optional relations to map this comment to a specific form payload
  timesheetId String?
  timesheet   Timesheet? @relation(fields: [timesheetId], references: [id])

  transferRecordId String?
  transferRecord   TransferRecord? @relation(fields: [transferRecordId], references: [id])

  incidentReportId String?
  incidentReport   IncidentReport? @relation(fields: [incidentReportId], references: [id])

  timeOffRequestId String?
  timeOffRequest   TimeOffRequest? @relation(fields: [timeOffRequestId], references: [id])

  fundingRequestId String?
  fundingRequest   FundingRequest? @relation(fields: [fundingRequestId], references: [id])

  capExRequestId String?
  capExRequest   CapExRequest? @relation(fields: [capExRequestId], references: [id])

  snowRemovalLogId String?
  snowRemovalLog   SnowRemovalLog? @relation(fields: [snowRemovalLogId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Timesheet {
  id          String @id @default(cuid())
  submitterId String
  submitter   User   @relation("TimesheetSubmitter", fields: [submitterId], references: [id])

  assignedTags Tag[] @relation("TimesheetTagApprovers")

  date         DateTime?
  timeIn       String?
  timeOut      String?
  lunchHour    Float?
  overTime     Float?
  transferTime Float?
  totalHours   Float?

  status   String    @default("PENDING") // PENDING, APPROVED, REJECTED
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransferRecord {
  id          String @id @default(cuid())
  submitterId String
  submitter   User   @relation("TransferSubmitter", fields: [submitterId], references: [id])

  assignedTags Tag[] @relation("TransferTagApprovers")

  date             DateTime?
  time             String?
  team             String?
  transferType     String? // "Standard", "M.E.", "Non-M.E. Police"
  
  callerName       String?
  callerPhone      String?
  funeralHome      String?
  funeralDirectorAssigning String? // Display string / id reference if needed
  destination      String? // Where to take the body
  deceasedName     String?
  deceasedAge      String?
  deceasedSex      String?
  deceasedDob      DateTime?
  deceasedDod      DateTime?
  placeOfDeath     String?
  
  valuables        String?
  nokName          String?
  nokRelation      String?
  nokContact       String?
  
  specialInstructions String?
  medicalExaminerName String?
  dateToME         DateTime?
  
  constName        String?
  constNumber      String?
  
  timeLeftMB       String?
  arriveScene      String?
  departScene      String?
  arriveHospital   String?
  mileageOut       String?
  mileageReturn    String?
  totalMileage     String?

  twoStaffApproved String? // Changed to String? since form submits 'Yes' or 'No'. DB type previously Boolean?
  notes            String?

  status   String    @default("PENDING")
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IncidentReport {
  id          String @id @default(cuid())
  submitterId String
  submitter   User   @relation("IncidentSubmitter", fields: [submitterId], references: [id])

  assignedTags Tag[] @relation("IncidentTagApprovers")

  incidentDate     DateTime?
  incidentLocation String?
  nature           String? // "Injury", "Damage", "Legal"
  notes            String?
  certified        String? // Checkbox value can be "on" or null

  status   String    @default("PENDING")
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimeOffRequest {
  id          String @id @default(cuid())
  submitterId String
  submitter   User   @relation("TimeOffSubmitter", fields: [submitterId], references: [id])

  assignedTags Tag[] @relation("TimeOffTagApprovers")

  startDate DateTime?
  endDate   DateTime?
  reason    String?

  status   String    @default("PENDING")
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FundingRequest {
  id          String @id @default(cuid())
  submitterId String
  submitter   User   @relation("FundingSubmitter", fields: [submitterId], references: [id])

  assignedTags Tag[] @relation("FundingTagApprovers")

  amount     Float?
  purpose    String?
  dateNeeded DateTime?

  status   String    @default("PENDING")
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CapExRequest {
  id          String @id @default(cuid())
  submitterId String
  submitter   User   @relation("CapExSubmitter", fields: [submitterId], references: [id])

  projectName String
  location    String
  budgetId    String?
  amount      Float
  quotes      String 

  status   String    @default("Pending")
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LocationBudget {
  id          String   @id @default(cuid())
  name        String   @default("General")
  location    String   // "MB", "CSG", "EVG", "EDENS"
  budget      Float    @default(0)
  lastResetAt DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SnowRemovalLog {
  id          String   @id @default(cuid())
  submitterId String
  submitter   User     @relation("SnowLogSubmitter", fields: [submitterId], references: [id])

  assignedTags Tag[]   @relation("SnowLogTagApprovers")

  date                DateTime?
  snowRemovalRequired String? // "Yes" or null
  iceSalt             String? // Checkbox "on"
  manualShoveling     String? // Checkbox "on"
  contractedPlow      String? // Checkbox "on"
  iceBreaking         String? // Checkbox "on"
  notes               String?

  status   String    @default("PENDING")
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  title     String
  message   String
  href      String?
  read      Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
